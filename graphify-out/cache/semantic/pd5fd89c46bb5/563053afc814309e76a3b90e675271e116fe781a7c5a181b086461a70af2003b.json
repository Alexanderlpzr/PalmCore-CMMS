{"nodes": [{"id": "agents_skills_laravel_best_practices_rules_queue_jobs", "label": "Queue & Job Best Practices (rules doc)", "file_type": "document", "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "queue_should_be_unique", "label": "ShouldBeUnique job contract", "file_type": "concept", "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prevents duplicate job processing by holding a lock keyed by uniqueId() until the job completes."}, {"id": "queue_should_be_unique_until_processing", "label": "ShouldBeUniqueUntilProcessing", "file_type": "concept", "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Releases the uniqueness lock once processing begins rather than on completion, allowing new instances to queue earlier than ShouldBeUnique permits."}, {"id": "queue_retry_after_timeout", "label": "retry_after must exceed job timeout", "file_type": "rationale", "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If retry_after is shorter than the job's timeout, the worker re-dispatches the job while it's still running, causing duplicate execution."}, {"id": "queue_exponential_backoff", "label": "Exponential backoff for job retries", "file_type": "concept", "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Progressively longer delays between retries avoid hammering a failing external service."}, {"id": "horizon_complex_queue_use", "label": "Use Horizon for complex queue scenarios", "file_type": "rationale", "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Recommended when monitoring, auto-scaling, failure tracking, or multiple priority queues are needed."}], "edges": [{"source": "agents_skills_laravel_best_practices_rules_queue_jobs", "target": "queue_should_be_unique", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "weight": 1.0}, {"source": "agents_skills_laravel_best_practices_rules_queue_jobs", "target": "queue_should_be_unique_until_processing", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "weight": 1.0}, {"source": "agents_skills_laravel_best_practices_rules_queue_jobs", "target": "queue_retry_after_timeout", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "weight": 1.0}, {"source": "agents_skills_laravel_best_practices_rules_queue_jobs", "target": "queue_exponential_backoff", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "weight": 1.0}, {"source": "agents_skills_laravel_best_practices_rules_queue_jobs", "target": "horizon_complex_queue_use", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/laravel-best-practices/rules/queue-jobs.md", "source_location": null, "weight": 1.0}, {"source": "queue_should_be_unique_until
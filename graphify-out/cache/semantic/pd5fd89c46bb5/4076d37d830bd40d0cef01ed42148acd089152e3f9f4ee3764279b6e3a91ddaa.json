{"nodes": [{"id": "agents_skills_laravel_best_practices_rules_testing", "label": "Testing Best Practices (rules doc)", "file_type": "document", "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "testing_lazily_refresh_database", "label": "LazilyRefreshDatabase over RefreshDatabase", "file_type": "concept", "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "RefreshDatabase migrates once per process; LazilyRefreshDatabase skips even that first migration when the schema is already up to date, saving time."}, {"id": "testing_model_assertions", "label": "Model assertions over raw database assertions", "file_type": "concept", "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "assertModelExists() is more expressive, type-safe, and fails with clearer messages than assertDatabaseHas()."}, {"id": "testing_event_fake_ordering", "label": "Call Event::fake() after factory setup", "file_type": "rationale", "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Factories rely on model events (e.g. creating to generate UUIDs); faking events before factory calls silences those events and produces broken models."}, {"id": "testing_recycle", "label": "recycle() to share relationship instances across factories", "file_type": "concept", "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Without recycle(), nested factories create separate instances of the same conceptual entity."}], "edges": [{"source": "agents_skills_laravel_best_practices_rules_testing", "target": "testing_lazily_refresh_database", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "weight": 1.0}, {"source": "agents_skills_laravel_best_practices_rules_testing", "target": "testing_model_assertions", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "weight": 1.0}, {"source": "agents_skills_laravel_best_practices_rules_testing", "target": "testing_event_fake_ordering", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "weight": 1.0}, {"source": "agents_skills_laravel_best_practices_rules_testing", "target": "testing_recycle", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "weight": 1.0}, {"source": "testing_lazily_refresh_database", "target": "pest_browser_testing", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.65, "source_file": ".agents/skills/laravel-best-practices/rules/testing.md", "source_location": null, "weight": 1.0}], "hyperedges": []}
{"nodes": [{"id": "claude_skills_laravel_best_practices_rules_architecture", "label": "Architecture Best Practices (rules doc)", "file_type": "document", "source_file": ".claude/skills/laravel-best-practices/rules/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_action_classes", "label": "Single-purpose Action classes", "file_type": "concept", "source_file": ".claude/skills/laravel-best-practices/rules/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Extract discrete business operations (e.g. CreateOrderAction) out of controllers for reuse and testability."}, {"id": "architecture_dependency_injection", "label": "Constructor dependency injection over app()/resolve()", "file_type": "rationale", "source_file": ".claude/skills/laravel-best-practices/rules/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Constructor injection is explicit and testable; app()/resolve() inside classes hides dependencies and complicates mocking."}, {"id": "architecture_defer_function", "label": "defer() for post-response fire-and-forget work", "file_type": "concept", "source_file": ".claude/skills/laravel-best-practices/rules/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Runs a callback after the HTTP response is sent in the same process, avoiding queue overhead; use real jobs when work must survive crashes or needs retries."}, {"id": "architecture_context_facade", "label": "Context facade for request-scoped data propagation", "file_type": "concept", "source_file": ".claude/skills/laravel-best-practices/rules/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "P
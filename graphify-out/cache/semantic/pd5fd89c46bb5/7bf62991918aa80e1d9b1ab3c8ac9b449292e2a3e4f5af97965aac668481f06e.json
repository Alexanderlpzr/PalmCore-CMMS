{"nodes": [{"id": "claude_skills_laravel_best_practices_rules_advanced_queries", "label": "Advanced Query Patterns (rules doc)", "file_type": "document", "source_file": ".claude/skills/laravel-best-practices/rules/advanced-queries.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "advqueries_addselect_subquery", "label": "addSelect() correlated subquery for single has-many value", "file_type": "concept", "source_file": ".claude/skills/laravel-best-practices/rules/advanced-queries.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pulls a single value (e.g. latest login) directly into the main SQL query with zero extra queries, instead of eager-loading an entire relation."}, {"id": "advqueries_wherein_vs_wherehas", "label": "whereIn + subquery preferred over whereHas", "file_type": "rationale", "source_file": ".claude/skills/laravel-best-practices/rules/advanced-queries.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "whereHas() emits a correlated EXISTS subquery re-executed per row; whereIn() with a select('id') subquery lets the database use an index lookup instead."}, {"id": "advqueries_compound_indexes", "label": "Compound indexes matching orderBy column order", "file_type": "concept", "source_file": ".claude/skills/laravel-best-practices/rules/advanced-queries.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Individual single-column indexes cannot combine for multi-column sorts; the database will filesort without a matching compound index."}], "edges": [{"source": "claude_skills_laravel_best_practices_rules_advanced_queries", "target": "advqueries_addselect_subquery", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/laravel-best-practices/rules/advanced-queries.md", "source_location": null, "weight": 1.0}, {"source": "claude_skills_laravel_best_practices_rules_advanced_queries", "target": "advqueries_wherein_vs_wherehas", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/laravel-best-practices/rules/advanced-queries.md", "source_location": null, "weight": 1.0}, {"source": "claude_skills_laravel_best_practices_rules_advanced_queries", "target": "advqueries_compound_indexes", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/laravel-best-practices/rules/advanced-queries.md", "source_location": null, "weight": 1.0}], "hyperedges": []}
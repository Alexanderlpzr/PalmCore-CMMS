APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.fronda.app

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

CORS_ALLOWED_ORIGINS=https://yourdomain.com
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Persistent file storage — keep "local" disks for development; in production
# point both to "r2" so uploads survive redeploys, restarts and scaling.
#   PERSISTENT_DISK=r2   (equipment photos, documents, logos, QR codes)
#   PRIVATE_DISK=r2      (work order media and other access-controlled files)
PERSISTENT_DISK=public
PRIVATE_DISK=work_orders_private

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 (S3-compatible object storage) — fill these and set
# PERSISTENT_DISK=r2 / PRIVATE_DISK=r2 to use cloud storage.
# Endpoint example: https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET=
R2_REGION=auto
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_USE_PATH_STYLE=true

VITE_APP_NAME="${APP_NAME}"

# Sentry — error tracking
SENTRY_LARAVEL_DSN=
VITE_SENTRY_DSN=
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=
SENTRY_RELEASE=

# Horizon — queue dashboard (requires QUEUE_CONNECTION=redis in production)
HORIZON_NAME=
HORIZON_PATH=horizon

# Backup — spatie/laravel-backup
BACKUP_MAIL_TO=admin@example.com
BACKUP_ARCHIVE_PASSWORD=
